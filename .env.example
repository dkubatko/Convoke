# Copy to .env and fill in. Generate keys with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"          # SECRET_KEY
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"  # FERNET_KEY

CONVOKE_OPERATOR_PASSWORD=change-me
CONVOKE_SECRET_KEY=
CONVOKE_FERNET_KEY=

# Optional overrides
#POSTGRES_PASSWORD=convoke
#CONVOKE_PORT=8080

# Public base URL the app is reached at (OAuth callbacks, links).
# Defaults to http://localhost:${CONVOKE_PORT}.
#CONVOKE_PUBLIC_URL=https://convoke.example.com

# Set true when serving over HTTPS so the session cookie is Secure-only.
#CONVOKE_COOKIE_SECURE=true

# Hugging Face token: unlocks gated embedding models (e.g. EmbeddingGemma).
#HF_TOKEN=
